{
  "name": "@kipr/server",
  "version": "0.0.0",
  "description": "KIPR backend cache/index — DERIVED data only (root hashes, message metadata). Never authoritative; fully reconstructable from 0G + the user's key.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "smoke:cache": "tsx src/smoke/cache.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kipr/core": "workspace:*",
    "@kipr/og": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
