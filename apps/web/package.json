{
  "name": "@kipr/web",
  "private": true,
  "version": "0.0.0",
  "description": "KIPR web client — React + Vite. P0: plumbing harness (wallet, 0G storage round-trip, gated compute).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
