    "selftest:export": "tsx src/lib/export.selftest.mts"
  },
  "dependencies": {
    "@0gfoundation/0g-compute-ts-sdk": "0.9.0-beta.0",
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.10",
    "@kipr/core": "workspace:*",
    "ethers": "6.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vite-plugin-node-polyfills": "^0.22.0"
  }
