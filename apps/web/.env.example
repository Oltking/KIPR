# KIPR web app env. Copy to .env.local and fill in.
# Privy app ID — PUBLIC client-side identifier (ships in the browser bundle).
# Get one free at https://dashboard.privy.io (create an app, add 0G Galileo as a
# custom chain). Without it, the app still runs in MetaMask-only mode.
VITE_PRIVY_APP_ID=

# Optional: pin a specific 0G Compute TeeML provider address for inference.
# VITE_ZG_COMPUTE_PROVIDER_ADDR=
