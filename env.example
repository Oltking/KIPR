# .env.example — KIPR
# Copy to .env and fill in real values. NEVER commit .env (add it to .gitignore).
# (confirm) = verify against research/ or the live wallet network before relying on it.

# --- 0G Chain (EVM) ---
ZG_EVM_RPC=https://evmrpc-testnet.0g.ai      # testnet; also seen as evmrpc-galileo.0g.ai (confirm). Mainnet = https://evmrpc.0g.ai
ZG_CHAIN_ID=16602                            # Galileo testnet (docs table) — some sources say 16601 (confirm). Mainnet = 16661

# --- Wallet (pays gas + storage/compute fees) ---
# Throwaway dev wallet only. Faucet (faucet.0g.ai) gives 0.1 0G/day — NOT enough for compute.
# Compute needs >=3 0G (ledger) + >=1 0G per provider: request testnet tokens from the 0G team early (Discord/contact in research).
ZG_PRIVATE_KEY=0x_your_funded_testnet_wallet_private_key_here

# --- 0G Storage (@0gfoundation/0g-storage-ts-sdk, v1.2.6+ for encryption) ---
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai   # mainnet = https://indexer-storage-turbo.0g.ai
# Flow contract is auto-discovered from the indexer — only set to override:
# ZG_STORAGE_FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296   # testnet (may change)

# --- 0G Compute (@0gfoundation/0g-compute-ts-sdk) ---
# Direct path uses the wallet above (no separate key). Pick a TeeML provider at runtime via broker.inference.listService().
# Optional: pin a provider/model so the build is deterministic.
ZG_COMPUTE_PROVIDER_ADDR=                    # (confirm) a TeeML provider address from listService()
ZG_COMPUTE_MODEL_ID=zai-org/GLM-5-FP8        # (confirm) example 0G-hosted model
# Router fallback only (unverified path) — get key at pc.0g.ai:
# ZG_ROUTER_BASE_URL=https://router-api.0g.ai/v1
# ZG_ROUTER_API_KEY=app-sk-...

# --- Memory backend (0g-memory / EverMemOS) ---
EVERMEMOS_BASE_URL=http://localhost:1995     # local memory REST API
# EVERMEMOS_API_KEY=                          # only in SERVER_MODE=true (multi-user)

# --- App ---
KIPR_JWT_SECRET=generate_a_long_random_string
KIPR_CACHE_DB_URL=postgres://localhost:5432/kipr_cache   # cache/index ONLY, not source of truth

# --- Dev only (NEVER used on any production path) ---
DEV_FALLBACK_MODEL_KEY=                       # local-only dev behind an explicit flag; leave blank otherwise
